{
  "name": "my-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "cross-env NODE_OPTIONS=--experimental-vm-modules npx expo start",
    "android": "cross-env NODE_OPTIONS=--experimental-vm-modules npx expo start --android",
    "ios": "cross-env NODE_OPTIONS=--experimental-vm-modules npx expo start --ios",
    "web": "cross-env NODE_OPTIONS=--experimental-vm-modules npx expo start --web",
    "start:loader": "cross-env NODE_OPTIONS=--experimental-vm-modules node --loader tsx ./node_modules/expo/bin/cli.js start",
    "verify-rls": "tsx lib/verify-rls.ts",
    "debug-auth": "tsx lib/debug-auth.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.97.0",
    "@tanstack/react-query": "^5.90.21",
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-status-bar": "~3.0.9",
    "nativewind": "^4.2.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/react": "19.1.0",
    "dotenv": "^16.4.5",
    "jwt-decode": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "~5.9.2",
    "cross-env": "^7.0.3"
  },
  "private": true
}
