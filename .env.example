# Supabase (copy to .env and fill in)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: when testing on a physical device or another VM, set to your machine's LAN IP
# so the app can reach Supabase in local Docker (avoids Windows host.docker.internal issues).
# Example: EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321 and EXPO_PUBLIC_SUPABASE_LOCAL_IP=192.168.1.100
# EXPO_PUBLIC_SUPABASE_LOCAL_IP=

# Optional: used by npm run verify-rls to sign in and assert RLS returns only your school's students
# TEST_USER_EMAIL=
# TEST_USER_PASSWORD=

# Optional: for npm run debug-auth (diagnose "Invalid login credentials", list users, force-reset password)
# SUPABASE_SERVICE_ROLE_KEY=
# DEBUG_RESET_PASSWORD=
